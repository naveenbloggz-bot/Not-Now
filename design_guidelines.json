{
  "identity": {
    "persona": "E1 - The Anti-AI Designer",
    "tone": "Luxury, Minimalist, High-Contrast, Swiss-Style",
    "principles": [
      "Fusion over Imitation: Mixing luxury fashion with Swiss distinctness.",
      "Emotion First: Desire and exclusivity.",
      "Content is King: The product is the hero.",
      "Negative Space: White space is the primary luxury signal.",
      "Contrast: Absolute Black vs Absolute White."
    ]
  },
  "typography": {
    "font_family": {
      "headings": "Montserrat, sans-serif",
      "body": "Lato, sans-serif"
    },
    "weights": {
      "headings": "Bold (700) or Black (900) for impact, Light (300) for elegance",
      "body": "Regular (400)"
    },
    "styles": {
      "h1": "text-5xl md:text-7xl font-bold tracking-tighter uppercase",
      "h2": "text-3xl md:text-5xl font-light tracking-wide uppercase",
      "h3": "text-xl md:text-2xl font-bold tracking-widest",
      "body": "text-base md:text-lg leading-relaxed text-gray-800",
      "label": "text-xs font-bold uppercase tracking-[0.2em]"
    }
  },
  "colors": {
    "palette": {
      "background": "#FFFFFF",
      "foreground": "#000000",
      "primary": "#000000",
      "secondary": "#FFFFFF",
      "accent": "#000000",
      "border": "#E5E5E5",
      "muted": "#F5F5F5",
      "error": "#FF0000"
    },
    "usage": {
      "background": "bg-white",
      "text_primary": "text-black",
      "text_secondary": "text-gray-600",
      "button_primary": "bg-black text-white hover:bg-gray-900",
      "button_secondary": "bg-white text-black border border-black hover:bg-black hover:text-white"
    }
  },
  "layout": {
    "container": "max-w-[1920px] mx-auto px-4 md:px-12",
    "grid": {
      "base": "grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8",
      "product_grid": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-y-12 gap-x-8"
    },
    "spacing": {
      "section_padding": "py-20 md:py-32",
      "element_spacing": "space-y-6"
    }
  },
  "components": {
    "button": {
      "style": "rounded-none uppercase tracking-[0.15em] font-bold text-sm h-12 px-8 transition-all duration-300",
      "variants": {
        "primary": "bg-black text-white border border-black hover:bg-transparent hover:text-black",
        "outline": "bg-transparent text-black border border-black hover:bg-black hover:text-white"
      }
    },
    "input": {
      "style": "border-0 border-b border-black rounded-none px-0 py-3 bg-transparent focus:ring-0 focus:border-black placeholder:text-gray-400"
    },
    "card": {
      "style": "group relative bg-white overflow-hidden",
      "image": "aspect-[3/4] object-cover w-full transition-transform duration-700 group-hover:scale-105"
    },
    "navbar": {
      "style": "sticky top-0 z-50 w-full bg-white/90 backdrop-blur-md border-b border-gray-100",
      "link": "uppercase tracking-[0.1em] text-xs font-bold hover:opacity-50 transition-opacity"
    }
  },
