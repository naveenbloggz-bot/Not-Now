  "universal_guidelines": [
    "Do not use gradients. Stick to solid black and white.",
    "Do not center everything blindly. Use the grid.",
    "Micro-animations are mandatory for every interactive element.",
    "Use 'sonner' for toasts.",
    "All interactive elements must have 'data-testid'.",
    "Do not use generic 'Inter' font. Use Montserrat/Lato pairing."
  ],
  "instructions_to_main_agent": [
    "Install 'lucide-react' for icons.",
    "Install '@radix-ui/react-slot' for Shadcn components if needed.",
    "Install 'framer-motion' for animations.",
    "Use 'clsx' and 'tailwind-merge' for class handling.",
    "Ensure 'Montserrat' and 'Lato' are imported via Google Fonts in index.css.",
    "Create a 'Layout' component that enforces the 'max-w-[1920px] mx-auto' constraint.",
    "Implement the 'HeroBanner' as a slider using 'embla-carousel-react' or similar lightweight library."
  ]
}